{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "tag": {
          "type": "string"
        }
      },
      "required": ["repository", "pullPolicy", "tag"]
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": ["name"],
        "additionalProperties": true
      }
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "podAnnotations": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "ports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "port": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "targetPort": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "protocol": {
                "type": "string",
                "enum": ["TCP", "UDP", "SCTP"]
              }
            },
            "required": ["name", "port", "targetPort", "protocol"]
          }
        }
      },
      "required": ["type", "annotations", "ports"]
    },
    "resources": {
      "type": "object"
    },
    "nodeSelector": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "tolerations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object"
    },
    "securityContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "privileged": {
          "type": "boolean"
        }
      },
      "required": ["privileged"]
    },
    "firewall": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "blockPrivateSubnets": {
          "type": "boolean"
        },
        "blockSubnets": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}\\/(?:[0-9]|[12][0-9]|3[0-2])$"
          }
        }
      },
      "required": ["blockPrivateSubnets", "blockSubnets"]
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "accessMode": {
          "type": "string",
          "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany", "ReadWriteOncePod"]
        },
        "size": {
          "type": "string",
          "minLength": 1
        },
        "storageClassName": {
          "type": "string"
        },
        "mountPath": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["enabled", "accessMode", "size", "storageClassName", "mountPath"]
    },
    "hostPaths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sshHostKeys": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "mountPath": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["enabled", "path", "mountPath"]
        },
        "rootSsh": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "mountPath": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["enabled", "path", "mountPath"]
        }
      },
      "required": ["sshHostKeys", "rootSsh"]
    },
    "podSecurityContext": {
      "type": "object"
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        }
      },
      "required": ["create", "annotations", "name"]
    }
  },
  "required": [
    "replicaCount",
    "image",
    "imagePullSecrets",
    "nameOverride",
    "fullnameOverride",
    "podAnnotations",
    "service",
    "resources",
    "nodeSelector",
    "tolerations",
    "affinity",
    "securityContext",
    "firewall",
    "persistence",
    "hostPaths",
    "podSecurityContext",
    "serviceAccount"
  ]
}
